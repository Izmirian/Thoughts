# --- Database ---
# Railway Postgres with the pgvector extension. Leave unset for local SQLite dev.
DATABASE_URL=

# --- AI (Claude) — used for image/PDF analysis and cluster labeling ---
ANTHROPIC_API_KEY=

# --- Embeddings (semantic similarity engine) ---
# Provider: voyage (default) | openai
EMBEDDING_PROVIDER=voyage
# voyage-3-lite = 512 dims. Change requires re-embedding existing rows.
VOYAGE_MODEL=voyage-3-lite
VOYAGE_API_KEY=
# Used if EMBEDDING_PROVIDER=openai, and/or for Whisper voice transcription.
OPENAI_API_KEY=

# --- Server / viewer ---
PORT=3000
# reminder-bot base URL for the status pill's server-side bot probe (optional).
BOT_HEALTH_URL=https://your-bot.up.railway.app
# Shared secret that gates the web viewer + /api/graph (personal data).
VIEWER_TOKEN=
# Shared secret that gates POST /api/ingest (must match reminder-bot's THOUGHTS_INGEST_SECRET).
THOUGHTS_INGEST_SECRET=

# --- Tuning (optional; sensible defaults live in src/config.js) ---
TOP_K=15
SIM_THRESHOLD=0.78
